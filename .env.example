# JAY-JAY MD - Environment Configuration
# Copy this file to .env and fill in your values

# WhatsApp Session ID (leave empty on first run to generate via QR code)
SESSION_ID=

# Bot Owner WhatsApp Number (with country code, no + or spaces)
# Example: 263771166781
OWNER_NUMBER=

# Bot Owner Name
OWNER_NAME=JAY JAY

# Secondary Owner Number (optional)
OWNER_NUMBER2=

# Developer Number (optional)
DEV=

# Bot Settings
PREFIX=.
BOT_NAME=JAY-JAY MD
STICKER_NAME=JAY-JAY MD
MODE=public
PUBLIC_MODE=true

# Auto Features
AUTO_STATUS_SEEN=true
AUTO_STATUS_REPLY=false
AUTO_STATUS_REACT=true
AUTO_STATUS_MSG=.𝗦𝗘𝗘𝗡 𝗬𝗢𝗨𝗥 𝗦𝗧𝗔𝗧𝗨𝗦 𝗕𝗬 𝗝𝗔𝗬-𝗝𝗔𝗬🔄
AUTO_BIO=true
AUTO_TYPING=true
AUTO_VOICE=true
AUTO_STICKER=false
AUTO_REPLY=true
AUTO_RECORDING=true
AUTO_REACT=false

# Protection Features
ANTI_LINK=true
ANTI_LINK_KICK=false
ANTI_BAD=true
ANTI_VV=true
ANTI_DEL_PATH=log

# Message Settings
MENTION_REPLY=true
READ_MESSAGE=false
READ_CMD=false
ALWAYS_ONLINE=false

# Channel & Group Links  
NEWSLETTER_JID=120363421014261315@newsletter
