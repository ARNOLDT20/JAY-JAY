# NPM Configuration for JAY-JAY MD Bot
# This ensures proper module installation and caching

# Use production dependencies only in production
#production=false

# Increase timeout for slow networks (Heroku)
fetch-timeout=120000
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000

# Proper npm cache behavior
#prefer-offline=true

# Build native modules if needed
build-from-source=false

# Strict SSL for security (Heroku requirement)
# strict-ssl=true

# Registry configuration
registry=https://registry.npmjs.org/

# Increase depth for dependency resolution
# depth=0

# Allow optional dependencies
# optional=true
